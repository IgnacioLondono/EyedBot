# Dependencias (se instalan en build)
node_modules
web/node_modules
web/panel/node_modules
web/panel/.next
web/panel/out
web/panel/.turbo

# Git / IDE / agentes
.git
.github
.cursor
.agent
**/.vscode
**/.idea

# Documentación (no necesaria en runtime)
*.md
!docker/mysql/**

# Datos y logs locales (volúmenes en runtime)
.env
.env.*
logs
backups
data
!data/.gitkeep

# Artefactos y cachés
*.log
npm-debug.log*
.DS_Store
Thumbs.db
**/*.tsbuildinfo
**/coverage
**/.vercel

# Proyectos duplicados / legacy en el workspace
TulaBot-main
EyedBot-clone
web/public
web/Dockerfile

# Docker (el contexto no necesita estos archivos dentro de la imagen)
docker-compose*.yml
Dockerfile
.dockerignore

# Tests y scripts solo de desarrollo
**/*.test.js
**/*.spec.js

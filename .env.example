# Discord (required)
DISCORD_TOKEN=tu_token_de_discord
CLIENT_ID=tu_client_id
CLIENT_SECRET=tu_client_secret
GUILD_ID=tu_guild_id
REDIRECT_URI=http://localhost:3000/callback
SESSION_SECRET=cambia_esta_clave_larga
SESSION_COOKIE_SECURE=false
WEB_PORT=3000
WEB_ENABLED=true
# Opcional — URL HTTPS pública si quieres que Discord cargue fotos solo por URL (túnel en dev).
# WEB_PUBLIC_ORIGIN=https://tudominio.com

# Audio / Music
MUSIC_ENABLED=false
MUSIC_DEFAULT_VOLUME=55
MUSIC_MAX_VOLUME=80
MUSIC_SKIP_FFMPEG=false
MUSIC_CLEAN_PROFILE_ENABLED=true
MUSIC_CLEAN_FILTERS=normalizer2,softlimiter
MUSIC_LEAVE_ON_EMPTY=true
MUSIC_LEAVE_ON_EMPTY_COOLDOWN_MS=90000
MUSIC_LEAVE_ON_END=true
MUSIC_LEAVE_ON_END_COOLDOWN_MS=180000
MUSIC_LEAVE_ON_STOP=true
MUSIC_LEAVE_ON_STOP_COOLDOWN_MS=30000
MUSIC_BUFFERING_TIMEOUT_MS=7000
MUSIC_CONNECTION_TIMEOUT_MS=45000
MUSIC_STRICT_ARTIST_MATCH=true

# Texto-a-voz en llamadas /tts (motor gratuito tipo Google Translate; límites no oficiales)
TTS_ENABLED=true
TTS_DEFAULT_LANG=es
# ID de voz del catálogo (ej. es_es · neutra, es_lat_aguda, en_gb_grave). Opcional si usas sólo código arriba.
# TTS_DEFAULT_VOICE=es_es
# Leer en voz los mensajes normales del canal de texto configurado (por defecto el de /tts unir o /tts escuchar)
TTS_READ_CHAT=true
# TTS_READ_MAX_CHARS=400
# Ignorar mensajes que empiecen por el prefijo guardado del bot (evitar leer comandos en voz)
# TTS_READ_SKIP_PREFIX=true
# Desconectar por inactividad (ms); 0 = no auto-salir (por defecto). Solo sale sin humanos en VC o con /tts desconectar
# TTS_IDLE_DISCONNECT_MS=0

# Performance tuning
CONFIG_CACHE_TTL_MS=120000
SLOW_COMMAND_WARN_MS=900

# Lavalink
# Requerido para música (Shoukaku → Lavalink). Levanta el servicio docker lavalink.
LAVALINK_ENABLED=true
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
# Primer arranque: el plugin YouTube puede tardar 1-2 min
# LAVALINK_HTTP_WARMUP_MS=90000
# LAVALINK_READY_TIMEOUT_MS=120000

# Optional APIs
TENOR_API_KEY=
GEMINI_API_KEY=

# Optional DB (not required for interaction counters now)
DB_HOST=mysql
DB_PORT=3306
DB_USER=tulabot
DB_PASSWORD=tulabot_password
DB_NAME=tulabot

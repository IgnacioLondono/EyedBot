# Discord (required)
DISCORD_TOKEN=tu_token_de_discord
CLIENT_ID=tu_client_id
CLIENT_SECRET=tu_client_secret
GUILD_ID=tu_guild_id
REDIRECT_URI=http://localhost:3000/callback
SESSION_SECRET=cambia_esta_clave_larga
# Para dominio HTTPS: true. Para IP local HTTP: false.
SESSION_COOKIE_SECURE=false
WEB_PORT=3000
WEB_ENABLED=true
# IDs con EyedPlus+ sin suscripción (coma-separados). Por defecto incluye el owner del panel.
WEB_PREMIUM_DISCORD_IDS=399740358101303316
WEB_OWNER_DISCORD_ID=tu_discord_user_id_owner
BOT_INVITE_PERMISSIONS=0
# Bind del panel (0.0.0.0 para acceder por IP local desde otros dispositivos)
WEB_BIND_IP=0.0.0.0
# Con nginx delante: 127.0.0.1 (solo localhost; nginx hace proxy HTTPS)
# WEB_BIND_HOST=127.0.0.1
# Solo si usas IP local en producción (HTTP) para pruebas LAN.
ALLOW_INSECURE_LOCAL_ORIGIN=true
# Lista opcional de orígenes extra permitidos por CORS (separados por coma)
# WEB_ALLOWED_ORIGINS=http://192.168.1.10:3000,http://10.0.0.20:3000
# Opcional — URL HTTPS pública si quieres que Discord cargue fotos solo por URL (túnel en dev).
# WEB_PUBLIC_ORIGIN=https://tudominio.com

# EyedPlus+ / premium del panel
# Si no está definido o es false, las funciones premium del panel quedan abiertas sin suscripción.
# Actívalo en producción cuando quieras exigir EyedPlus+: EYEDPLUS_REQUIRED=true
# EYEDPLUS_REQUIRED=false
# Proveedor de pago: auto (WebPay si está configurado, si no Mercado Pago), webpay o mercadopago
BILLING_PROVIDER=auto
# WebPay (Transbank) — recomendado para Chile
WEBPAY_COMMERCE_CODE=
WEBPAY_API_KEY=
# integration | production
WEBPAY_ENV=integration
# Monto en pesos chilenos (entero, sin decimales)
WEBPAY_MONTHLY_AMOUNT=4990
WEBPAY_PERIOD_DAYS=30
WEBPAY_PRODUCT_NAME=EyedPlus+ mensual
# Credenciales de integración Transbank (solo pruebas):
# WEBPAY_COMMERCE_CODE=597055555532
# WEBPAY_API_KEY=579B532A7440BB0C9079D78449D625C
# Usa token de test mientras integras Mercado Pago (TEST-...)
MP_ACCESS_TOKEN=
# Se usa para validación básica de firma (opcional)
MP_WEBHOOK_SECRET=
# Opcional: etiqueta del cobro mensual
MP_REASON=EyedPlus+ mensual
# Opcional: moneda y monto mensual
MP_CURRENCY_ID=USD
MP_MONTHLY_AMOUNT=9.99

# Música + Lavalink (desactivado por defecto)
MUSIC_ENABLED=false
LAVALINK_ENABLED=false
# Para activar: MUSIC_ENABLED=true, LAVALINK_ENABLED=true, docker compose --profile music up -d
# MUSIC_DEFAULT_VOLUME=55
# MUSIC_MAX_VOLUME=80
# LAVALINK_HOST=lavalink
# LAVALINK_PORT=2333
# LAVALINK_PASSWORD=clave_larga_lavalink

# Texto-a-voz en llamadas /tts (motor gratuito tipo Google Translate; límites no oficiales)
TTS_ENABLED=true
TTS_DEFAULT_LANG=es
# ID de voz del catálogo (ej. es_es · neutra, es_lat_aguda, en_gb_grave). Opcional si usas sólo código arriba.
# TTS_DEFAULT_VOICE=es_es
# TEMP_VOICE_PROTECTED_USER_IDS=123456789,987654321
# FORCED_SLASH_GUILD_IDS=123456789012345678
# Leer en voz los mensajes normales del canal de texto configurado (por defecto el de /tts unir o /tts escuchar)
TTS_READ_CHAT=true
# TTS_READ_MAX_CHARS=0
# 0 = leer el mensaje completo (hasta ~2000 de Discord). Ej.: 500 para acortar.
# TTS_READ_OWNER_ONLY=true
# true = solo lee mensajes del usuario que ejecutó /tts unir. false = lee a todos en el canal.
# TTS_MAX_INPUT=0
# 0 = sin tope al sintetizar (se trocea solo para Google). Ej.: 900 para limitar por línea.
# Ignorar mensajes que empiecen por el prefijo guardado del bot (evitar leer comandos en voz)
# TTS_READ_SKIP_PREFIX=true
# Desconectar por inactividad (ms); 0 = no auto-salir (por defecto). Solo sale sin humanos en VC o con /tts desconectar
# TTS_IDLE_DISCONNECT_MS=0

# Performance tuning
CONFIG_CACHE_TTL_MS=120000
SLOW_COMMAND_WARN_MS=900

# Bienvenidas — tarjeta con imagen personalizable en el panel (true/false)
WELCOME_CARD_STYLE_ENABLED=true

# Niveles — MySQL es la fuente principal; JSON local solo si LEVELING_FILE_MIRROR=true
# LEVELING_FILE_MIRROR=false

# Optional APIs
TENOR_API_KEY=
GEMINI_API_KEY=

# Billing — WebPay (Chile) o Mercado Pago
BILLING_PROVIDER=auto
WEBPAY_COMMERCE_CODE=
WEBPAY_API_KEY=
WEBPAY_ENV=integration
WEBPAY_MONTHLY_AMOUNT=4990
WEBPAY_PERIOD_DAYS=30
# Billing (Mercado Pago) — obligatorio con firma en producción
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=clave_hmac_larga_obligatoria_en_prod
MP_MONTHLY_AMOUNT=9.99
MP_CURRENCY_ID=USD

# ─── Directos (Twitch + YouTube + TikTok) — requiere panel web accesible por HTTPS ───
# URL pública del panel (obligatorio para avisos instantáneos)
WEB_PUBLIC_ORIGIN=https://tudominio.com

# Twitch EventSub
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_EVENTSUB_SECRET=clave_aleatoria_larga_min_10_chars

# YouTube: WebSub push + API para confirmar que el vídeo está EN VIVO
YOUTUBE_API_KEY=

# Callbacks opcionales (si no se definen, se derivan de WEB_PUBLIC_ORIGIN)
# TWITCH_EVENTSUB_CALLBACK_URL=https://tudominio.com/webhooks/twitch/eventsub
# (YouTube y feeds usan /webhooks/youtube/websub y /webhooks/feed/websub)

# TikTok sin feed RSS: comprobación cada ~40 s (no hay webhook oficial de TikTok)
# TIKTOK_LIVE_CHECK_MS=40000

# Respaldo general si falla un webhook (ms). Default ~15 min con push activo
# STREAM_ALERT_CHECK_MS=900000

# Crunchyroll — avisos de episodios nuevos (API no oficial; puede fallar por Cloudflare)
# CRUNCHYROLL_API_BASE=https://beta-api.crunchyroll.com
# CRUNCHYROLL_LOCALE=es-ES
# CRUNCHYROLL_CHECK_MS=1200000
# CRUNCHYROLL_FETCH_TIMEOUT_MS=20000

# MySQL — datos en disco OMV (plusultra). Dev local: MYSQL_DATA_PATH=./data/mysql
MYSQL_DATA_PATH=/srv/dev-disk-by-uuid-a5b4e34c-5e9b-430c-93ad-0473fe6143d2/data/Etc/Eyedbot/mysql

# Compose bridge (mysql en el stack): DB_HOST=mysql
# Host mode + nginx (MySQL nativo o puerto 3306 en el host): DB_HOST=127.0.0.1
DB_HOST=mysql
DB_PORT=3306
DB_USER=tulabot
DB_PASSWORD=tulabot_password
DB_NAME=tulabot
MYSQL_ROOT_PASSWORD=cambia_este_root_password
